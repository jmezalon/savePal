# Database
DATABASE_URL="postgresql://user:password@localhost:5432/savepal?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV="development"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Twilio
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# SendGrid
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL=""

# Email Configuration (Gmail SMTP)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="noreply@save-pals.com"
EMAIL_PASSWORD="your-gmail-app-password"
EMAIL_FROM="noreply@save-pals.com"
SUPPORT_EMAIL="support@save-pals.com"

# Frontend URL
FRONTEND_URL="http://localhost:5173"
