// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User Model
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  firstName     String
  lastName      String
  phoneNumber   String?
  emailVerified Boolean  @default(false)
  phoneVerified Boolean  @default(false)
  trustScore    Float    @default(0)
  role          SystemRole @default(USER)

  // Notification Preferences
  emailNotifications Boolean @default(true)
  smsNotifications   Boolean @default(false)
  pushNotifications  Boolean @default(true)

  // Password Reset
  resetToken       String?
  resetTokenExpiry DateTime?

  // Email Verification
  emailVerificationToken String?

  // Phone Verification
  phoneVerificationToken String?
  phoneVerificationExpiry DateTime?

  // Stripe
  stripeCustomerId         String?  @unique
  stripeConnectAccountId   String?  @unique
  stripeConnectOnboarded   Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  memberships     Membership[]
  payments        Payment[]
  createdGroups   Group[]        @relation("GroupCreator")
  receivedPayouts Payout[]
  notifications   Notification[]
  paymentMethods  PaymentMethod[]

  @@map("users")
}

// Group Model
model Group {
  id                 String       @id @default(uuid())
  name               String
  description        String?
  contributionAmount Float
  frequency          Frequency
  payoutMethod       PayoutMethod
  status             GroupStatus  @default(PENDING)
  maxMembers         Int
  currentMembers     Int          @default(0)
  startDate          DateTime?
  endDate            DateTime?
  inviteCode         String       @unique @default(uuid())
  createdById        String
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  // Relations
  createdBy    User           @relation("GroupCreator", fields: [createdById], references: [id])
  memberships  Membership[]
  cycles       Cycle[]
  notifications Notification[]

  @@map("groups")
}

// Membership Model
model Membership {
  id             String     @id @default(uuid())
  groupId        String
  userId         String
  role           MemberRole @default(MEMBER)
  payoutPosition Int
  joinedAt       DateTime   @default(now())
  isActive       Boolean    @default(true)

  // Relations
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@unique([groupId, payoutPosition])
  @@map("memberships")
}

// Cycle Model
model Cycle {
  id            String    @id @default(uuid())
  groupId       String
  cycleNumber   Int
  recipientId   String
  dueDate       DateTime
  completedDate DateTime?
  totalAmount   Float
  isCompleted   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  group    Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payments Payment[]
  payout   Payout?

  @@unique([groupId, cycleNumber])
  @@map("cycles")
}

// Payment Model
model Payment {
  id                     String        @id @default(uuid())
  cycleId                String
  userId                 String
  amount                 Float
  status                 PaymentStatus @default(PENDING)
  stripePaymentIntentId  String?       @unique
  stripeChargeId         String?
  failureReason          String?
  retryCount             Int           @default(0)
  paidAt                 DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  // Relations
  cycle Cycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cycleId, userId])
  @@map("payments")
}

// Payout Model
model Payout {
  id                    String        @id @default(uuid())
  cycleId               String        @unique
  recipientId           String
  amount                Float
  feeAmount             Float
  netAmount             Float
  status                PaymentStatus @default(PENDING)
  stripeTransferId      String?       @unique
  transferredAt         DateTime?
  failureReason         String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  // Relations
  cycle     Cycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  recipient User  @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@map("payouts")
}

// Payment Method Model
model PaymentMethod {
  id                     String   @id @default(uuid())
  userId                 String
  stripePaymentMethodId  String   @unique
  type                   String
  last4                  String
  brand                  String?
  expiryMonth            Int?
  expiryYear             Int?
  isDefault              Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payment_methods")
}

// Notification Model
model Notification {
  id        String           @id @default(uuid())
  userId    String
  groupId   String?
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  sentAt    DateTime         @default(now())
  createdAt DateTime         @default(now())

  // Relations
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// Enums
enum Frequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum PayoutMethod {
  SEQUENTIAL
  RANDOM
  BIDDING
}

enum GroupStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum SystemRole {
  USER
  SUPERADMIN
}

enum NotificationType {
  PAYMENT_DUE
  PAYMENT_RECEIVED
  PAYOUT_PENDING
  PAYOUT_COMPLETED
  PAYOUT_FAILED
  GROUP_INVITE
  GROUP_STARTED
  GROUP_COMPLETED
  PAYMENT_FAILED
  CONNECT_ONBOARDING_REQUIRED
  REMINDER
}
