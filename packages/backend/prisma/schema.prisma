// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User Model
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String?
  firstName     String
  lastName      String
  googleId      String?  @unique
  appleId       String?  @unique
  phoneNumber   String?
  emailVerified Boolean  @default(false)
  phoneVerified Boolean  @default(false)
  trustScore    Float    @default(0)
  role          SystemRole @default(USER)

  // Notification Preferences
  emailNotifications Boolean @default(true)
  smsNotifications   Boolean @default(false)
  pushNotifications  Boolean @default(true)

  // Password Reset
  resetToken       String?
  resetTokenExpiry DateTime?

  // Email Verification
  emailVerificationToken String?

  // Phone Verification
  phoneVerificationToken String?
  phoneVerificationExpiry DateTime?

  // Stripe
  stripeCustomerId         String?  @unique
  stripeConnectAccountId   String?  @unique
  stripeConnectOnboarded   Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  memberships         Membership[]
  payments            Payment[]
  createdGroups       Group[]              @relation("GroupCreator")
  receivedPayouts     Payout[]
  notifications       Notification[]
  paymentMethods      PaymentMethod[]
  groupCreationFees   GroupCreationFee[]
  feeWaiverCodeUsages FeeWaiverCodeUsage[]
  deviceTokens        DeviceToken[]

  @@map("users")
}

// Group Model
model Group {
  id                 String       @id @default(uuid())
  name               String
  description        String?
  contributionAmount Float
  frequency          Frequency
  payoutFrequency    Frequency?
  payoutMethod       PayoutMethod
  status             GroupStatus  @default(PENDING)
  maxMembers         Int
  currentMembers     Int          @default(0)
  startDate          DateTime?
  endDate            DateTime?
  inviteCode         String       @unique @default(uuid())
  createdById        String
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  // Relations
  createdBy    User           @relation("GroupCreator", fields: [createdById], references: [id])
  memberships  Membership[]
  cycles       Cycle[]
  notifications Notification[]
  creationFee  GroupCreationFee?
  feeWaiverCodeUsage FeeWaiverCodeUsage?

  @@map("groups")
}

// Membership Model
model Membership {
  id             String     @id @default(uuid())
  groupId        String
  userId         String
  role           MemberRole @default(MEMBER)
  payoutPosition Int
  joinedAt       DateTime   @default(now())
  isActive       Boolean    @default(true)
  autoPaymentConsented   Boolean  @default(false)
  autoPaymentConsentedAt DateTime?

  // Debt tracking for fallback payment enforcement
  outstandingDebt   Float    @default(0)
  debtPaymentIds    String[] @default([])

  // Relations
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@unique([groupId, payoutPosition])
  @@map("memberships")
}

// Cycle Model
model Cycle {
  id            String    @id @default(uuid())
  groupId       String
  cycleNumber   Int
  recipientId   String
  dueDate       DateTime
  completedDate DateTime?
  totalAmount   Float
  isCompleted   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  group    Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payments Payment[]
  payout   Payout?

  @@unique([groupId, cycleNumber])
  @@map("cycles")
}

// Payment Model
model Payment {
  id                     String        @id @default(uuid())
  cycleId                String
  userId                 String
  amount                 Float
  status                 PaymentStatus @default(PENDING)
  contributionPeriod     Int           @default(1)
  dueDate                DateTime?
  stripePaymentIntentId  String?       @unique
  stripeChargeId         String?
  failureReason          String?
  retryCount             Int           @default(0)
  paidAt                 DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  // Fallback payment tracking
  fallbackMethod         String?       // 'payout_withholding' | null
  fallbackAt             DateTime?

  // Relations
  cycle Cycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cycleId, userId, contributionPeriod])
  @@index([dueDate, status])
  @@map("payments")
}

// Payout Model
model Payout {
  id                    String        @id @default(uuid())
  cycleId               String        @unique
  recipientId           String
  amount                Float
  feeAmount             Float
  netAmount             Float
  status                PaymentStatus @default(PENDING)
  stripeTransferId      String?       @unique
  transferredAt         DateTime?
  failureReason         String?
  retryCount            Int           @default(0)
  lastRetryAt           DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  // Relations
  cycle     Cycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  recipient User  @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@map("payouts")
}

// Payment Method Model
model PaymentMethod {
  id                     String   @id @default(uuid())
  userId                 String
  stripePaymentMethodId  String   @unique
  type                   String
  last4                  String
  brand                  String?
  expiryMonth            Int?
  expiryYear             Int?
  isDefault              Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payment_methods")
}

// Notification Model
model Notification {
  id        String           @id @default(uuid())
  userId    String
  groupId   String?
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  sentAt    DateTime         @default(now())
  createdAt DateTime         @default(now())

  // Relations
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// Device Token Model (for push notifications)
model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String   // 'ios' | 'android' | 'web'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("device_tokens")
}

// Enums
enum Frequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum PayoutMethod {
  SEQUENTIAL
  RANDOM
  BIDDING
}

enum GroupStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum SystemRole {
  USER
  SUPERADMIN
}

enum NotificationType {
  PAYMENT_DUE
  PAYMENT_RECEIVED
  PAYOUT_PENDING
  PAYOUT_COMPLETED
  PAYOUT_FAILED
  GROUP_INVITE
  GROUP_STARTED
  GROUP_COMPLETED
  PAYMENT_FAILED
  CONNECT_ONBOARDING_REQUIRED
  REMINDER
  AUTO_PAYMENT_SCHEDULED
  AUTO_PAYMENT_PROCESSED
  DEBT_RECORDED
  DEBT_DEDUCTED_FROM_PAYOUT
  PAYMENT_DISPUTED
}

enum CreationFeeStatus {
  COMPLETED
  WAIVED
}

// Fee Waiver Code Model
model FeeWaiverCode {
  id          String   @id @default(uuid())
  code        String   @unique
  description String?
  maxUses     Int?     // null = unlimited
  currentUses Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  usages FeeWaiverCodeUsage[]

  @@map("fee_waiver_codes")
}

// Fee Waiver Code Usage Model
model FeeWaiverCodeUsage {
  id     String   @id @default(uuid())
  codeId String
  userId String
  groupId String  @unique
  usedAt DateTime @default(now())

  // Relations
  code  FeeWaiverCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([codeId, userId, groupId])
  @@map("fee_waiver_code_usages")
}

// Group Creation Fee Model
model GroupCreationFee {
  id                    String            @id @default(uuid())
  groupId               String            @unique
  userId                String
  amount                Float
  status                CreationFeeStatus
  waiverReason          String?
  stripePaymentIntentId String?           @unique
  createdAt             DateTime          @default(now())

  // Relations
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("group_creation_fees")
}
